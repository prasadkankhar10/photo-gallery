{
  "name": "photo-management-system",
  "version": "1.0.0",
  "description": "Local-first AI-powered Photo Management System",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server/server.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "start": "node server/server.js"
  },
  "dependencies": {
    "@google/genai": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "face-api.js": "^0.22.2",
    "lucide-react": "^0.378.0",
    "multer": "^1.4.5-lts.1",
    "node-telegram-bot-api": "^0.65.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11"
  }
